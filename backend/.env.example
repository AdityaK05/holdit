# ── Core Infrastructure ───────────────────────────────────────────────────────
# Docker: uses postgres/redis containers; Production: use managed services
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/holdit
REDIS_URL=redis://localhost:6379/0

# ── Auth & Security ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRY=3600
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=100

# ── Database Connection Pool ─────────────────────────────────────────────────
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ── Payment Configuration ────────────────────────────────────────────────────
PAYMENT_EXPIRY_MINUTES=30

# ── Gunicorn (production only) ───────────────────────────────────────────────
GUNICORN_WORKERS=2

# ── Razorpay (leave blank for mock gateway mode) ─────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── SMTP Email (leave blank to skip email notifications) ─────────────────────
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=noreply@holdit.com

# ── Optional Integrations ────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=
GOOGLE_CLIENT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ── Monitoring (leave blank to disable) ──────────────────────────────────────
SENTRY_DSN=
